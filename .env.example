# Vosj Community Edition — environment configuration (copy to .env)
# Every value has a safe default EXCEPT the fail-closed secrets below.

# --- HTTP ---
VOSJ_PORT=8080

# --- State store: 'pg' or 'memory'. Defaults to 'pg' when DB is configured, else 'memory'. ---
VOSJ_STATE_STORE=

# --- PostgreSQL (leave blank to run with the in-memory StateStore) ---
PG_HOST=
PG_PORT=5432
PG_USER=
PG_PASSWORD=
PG_DATABASE=
# CloudNativePG ships a self-signed cert; set to 'false' to accept it (§14.4 durability path).
VOSJ_DB_SSL_REJECT_UNAUTHORIZED=true

# --- Ledger signing (REQUIRED to sign; fail-closed if missing — never a default key, §12.2/§14.4) ---
# Custody outside the DB (KMS/HSM/vault). Generate: openssl rand -hex 32
VOSJ_LEDGER_HMAC_KEY=

# --- Credential vault (REQUIRED for vault ops; fail-closed if missing — never a default dev key, §15.2) ---
VOSJ_VAULT_MASTER_KEY=

# --- Auth: 'token' (bearer) or 'open' (localhost dev only) ---
VOSJ_AUTH_MODE=token
VOSJ_AUTH_TOKEN=
