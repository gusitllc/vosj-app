# =============================================================================
# deploy/poc/config.env — single source of truth for the Vosj POC automation.
#
# Every tunable lives here. The scripts (00..40, deploy-all, teardown) source
# this file and NEVER hardcode a path, id, registry, or threshold. NO secrets
# are stored here — the fail-closed keys (VOSJ_LEDGER_HMAC_KEY /
# VOSJ_VAULT_MASTER_KEY / VOSJ_AUTH_TOKEN) are generated at deploy time with
# `openssl rand -hex 32` and pushed straight into a Kubernetes Secret.
#
# Override any value by editing this file, or by exporting it before invoking a
# script (every line below uses `${VAR:-default}` so an exported env wins).
#
# Usage:
#   cp config.env config.env   # already here; edit in place
#   ./deploy-all.sh --target azure-local
# =============================================================================

# ----------------------------------------------------------------------------
# TARGET — which Kubernetes substrate to provision.
#   azure-local : AKS enabled by Azure Arc on an Azure Local (Azure Stack HCI)
#                 instance, via `az aksarc`. This is the POC default.
#   azure       : managed cloud AKS, via `az aks`.
# The --target flag on deploy-all.sh / 00-provision-cluster.sh overrides this.
# ----------------------------------------------------------------------------
export TARGET="${TARGET:-azure-local}"

# ----------------------------------------------------------------------------
# Azure account / scope
# ----------------------------------------------------------------------------
export SUBSCRIPTION="${SUBSCRIPTION:-a16d84c5-15b4-4f50-a06c-5e5064d9345c}"
export RESOURCE_GROUP="${RESOURCE_GROUP:-rg-avd-1node-gpu}"
# Azure region for managed AKS (TARGET=azure only). Ignored for azure-local
# (the cluster inherits the location of its custom location / Azure Local).
export LOCATION="${LOCATION:-eastus}"

# ----------------------------------------------------------------------------
# Cluster identity
# ----------------------------------------------------------------------------
export CLUSTER_NAME="${CLUSTER_NAME:-vosj-poc}"
# Kubernetes version. Leave blank to let Azure pick the default for the target.
# Confirm available versions with: az aksarc get-versions / az aks get-versions.
export K8S_VERSION="${K8S_VERSION:-1.32.9}"   # proven on this infra (matches live Luca-prod)

# ----------------------------------------------------------------------------
# Azure Local (TARGET=azure-local) specifics
# ----------------------------------------------------------------------------
# Custom location (extendedLocation) of the Azure Local instance. Full ARM id.
export CUSTOM_LOCATION="${CUSTOM_LOCATION:-/subscriptions/a16d84c5-15b4-4f50-a06c-5e5064d9345c/resourceGroups/rg-avd-1node-gpu/providers/Microsoft.ExtendedLocation/customLocations/fl-small-gpu-mocarb-cl}"

# Logical network NAME to attach the cluster to. Default is the DHCP network so
# the POC needs no static IP planning. Alternatives on this instance:
#   small-fl-logicaln-dhcp  (DHCP — default)
#   small-fl-logical-st     (static)
#   fl-small-gpu-InfraLNET  (infra)
export LOGICAL_NETWORK="${LOGICAL_NETWORK:-small-fl-logical-st}"   # static net w/ subnet 192.168.1.0/24 + pool .80-.98 (aksarc needs a defined subnet)

# Full ARM resource id of the logical network, passed to `--vnet-ids`. By
# default it is composed from RESOURCE_GROUP + LOGICAL_NETWORK. Override
# directly if the logical network lives in a different resource group.
export LOGICAL_NETWORK_ID="${LOGICAL_NETWORK_ID:-/subscriptions/${SUBSCRIPTION}/resourceGroups/${RESOURCE_GROUP}/providers/Microsoft.AzureStackHCI/logicalNetworks/${LOGICAL_NETWORK}}"

# ----------------------------------------------------------------------------
# Cluster sizing — modest, this is a SMALL 1-node Azure Local instance.
# ----------------------------------------------------------------------------
export CONTROL_PLANE_COUNT="${CONTROL_PLANE_COUNT:-1}"
export NODE_COUNT="${NODE_COUNT:-1}"
# Small VM sizes recommended for the 1-node instance: Standard_A4_v2 (8GB) or
# Standard_A2_v2 (4GB). A4_v2 gives Vosj + a couple of devstations headroom.
export NODE_VM_SIZE="${NODE_VM_SIZE:-Standard_A4_v2}"
# Control plane MUST use an aksarc control-plane VM size. Standard_K8S3_v1 is the
# PROVEN size on this infra (matches the live Luca-prod cluster); a general size
# like A4_v2 is not valid for the aksarc control plane.
export CONTROL_PLANE_VM_SIZE="${CONTROL_PLANE_VM_SIZE:-Standard_K8S3_v1}"
# Static control-plane APIServer IP (az aksarc --control-plane-ip). Must be a FREE
# IP in the logical-network subnet (192.168.1.0/24), OUTSIDE the node pool (.80-.98)
# and clear of Luca-prod CP (.69), infra (.31-.33), .249 and .254. .70 is free.
export CONTROL_PLANE_IP="${CONTROL_PLANE_IP:-192.168.1.70}"

# SSH key handling for the node VMs. `--generate-ssh-keys` autocreates a keypair
# under ~/.ssh if none exists. To use your own, set SSH_KEY_VALUE to a public
# key path and the provisioner passes `--ssh-key-value` instead.
export SSH_KEY_VALUE="${SSH_KEY_VALUE:-}"

# ----------------------------------------------------------------------------
# Container registry & image
# ----------------------------------------------------------------------------
export ACR="${ACR:-lucaexpressacr}"
# IMAGE_TAG defaults to a timestamp so each build is uniquely addressable and we
# never deploy a floating :latest. Override to pin a specific build.
export IMAGE_TAG="${IMAGE_TAG:-poc-$(date +%Y%m%d%H%M)}"
export IMAGE_NAME="${IMAGE_NAME:-vosj-ce}"
# Fully-qualified image reference the cluster pulls. Composed from ACR + tag.
export IMAGE_REPOSITORY="${IMAGE_REPOSITORY:-${ACR}.azurecr.io/${IMAGE_NAME}}"
# docker-registry pull Secret created per-namespace so the cluster can pull from the
# PRIVATE ACR (built from `az acr credential show`). The chart wires it via
# .Values.imagePullSecrets. Set ACR_PULL_SECRET="" to skip (e.g. cluster has ACR
# attached via managed identity / --attach-acr).
export ACR_PULL_SECRET="${ACR_PULL_SECRET:-vosj-acr-pull}"

# Seat Manager image (the standalone credential-assignment console, stage 50). Built
# from deploy/poc/seat-manager/ by 50-deploy-seat-manager.sh / seat-manager/build.sh.
export SEAT_MANAGER_IMAGE="${SEAT_MANAGER_IMAGE:-${ACR}.azurecr.io/vosj-seat-manager:poc}"
# Community-Edition seat cap — the Seat Manager can scale seats from 1 up to this
# (default 5; the UI exposes a 1..SEAT_MAX control). 50 = the CE limit.
export SEAT_MAX="${SEAT_MAX:-50}"

# ----------------------------------------------------------------------------
# Namespaces
# ----------------------------------------------------------------------------
export NAMESPACE_VOSJ="${NAMESPACE_VOSJ:-vosj}"
export NAMESPACE_DEV="${NAMESPACE_DEV:-devstations}"

# ----------------------------------------------------------------------------
# Vosj deployment options
# ----------------------------------------------------------------------------
# State store for the POC: 'memory' (no DB, ephemeral, demo) or 'pg'.
# memory is the POC default — VOSJ_STATE_STORE=memory works with no DB and skips
# the Postgres stage (15) entirely. Set VOSJ_STATE_STORE=pg to turn the Postgres
# path ON: stage 15 deploys a real PERSISTENT Postgres (postgres.yaml), stage 20
# points Vosj at it (helm --set config.stateStore=pg + the PG_* values below) and
# the chart's migration Job runs `npm run migrate` against it before the rollout.
export VOSJ_STATE_STORE="${VOSJ_STATE_STORE:-memory}"
# Helm release name.
export VOSJ_RELEASE="${VOSJ_RELEASE:-vosj}"
# Replica count for the POC (small node → keep it at 1).
export VOSJ_REPLICAS="${VOSJ_REPLICAS:-1}"
# Name of the fail-closed Secret the scripts create and the chart references.
# This Secret is ALSO the single source of the PG_PASSWORD — Postgres sources its
# POSTGRES_PASSWORD from the SAME Secret/key, so the DB and the app can never
# disagree on credentials. No second copy of the password is stored anywhere.
export VOSJ_SECRET_NAME="${VOSJ_SECRET_NAME:-vosj-secret}"

# ----------------------------------------------------------------------------
# PostgreSQL (used ONLY when VOSJ_STATE_STORE=pg — see 15-deploy-postgres.sh +
# postgres.yaml). In memory mode every value below is ignored and no DB is
# deployed. These NON-SECRET connection parts are passed to the chart via
# `helm --set config.postgres.*`; the password is NOT here — it is the generated
# PG_PASSWORD inside $VOSJ_SECRET_NAME (single-sourced, see above).
# ----------------------------------------------------------------------------
# In-cluster Service name + port the app connects to. PG_HOST is a bare Service
# name because Postgres is deployed in the SAME namespace as Vosj, so it resolves
# directly. MUST equal $PG_SERVICE.
export PG_SERVICE="${PG_SERVICE:-vosj-postgres}"
export PG_HOST="${PG_HOST:-vosj-postgres}"
export PG_PORT="${PG_PORT:-5432}"
# Database user + database name. These must match the chart's config.postgres.user
# / config.postgres.database (20-deploy-vosj.sh passes the same values) AND the
# Postgres container's POSTGRES_USER / POSTGRES_DB (postgres.yaml).
export PG_USER="${PG_USER:-vosj}"
export PG_DATABASE="${PG_DATABASE:-vosj}"
# The ONE Postgres PVC size (default storageClass). A single long-lived PVC is the
# supported pattern; the CSI hazard is MANY simultaneous per-pod attaches, not one.
export PG_STORAGE="${PG_STORAGE:-5Gi}"
# Postgres image — pinned (never :latest). Alpine keeps the small-node footprint low.
export PG_IMAGE="${PG_IMAGE:-postgres:16-alpine}"
# Postgres resource sizing — modest, fits a small 1-worker Azure Local node.
export PG_CPU_REQUEST="${PG_CPU_REQUEST:-100m}"
export PG_CPU_LIMIT="${PG_CPU_LIMIT:-1}"
export PG_MEM_REQUEST="${PG_MEM_REQUEST:-256Mi}"
export PG_MEM_LIMIT="${PG_MEM_LIMIT:-512Mi}"
# Whether to use TLS toward Postgres AT ALL. Plain in-cluster postgres:16-alpine
# serves NO TLS — passing any ssl object makes node-postgres fail the handshake
# with "The server does not support SSL connections". So this POC sets it 'false'
# to disable TLS entirely (src/config.js -> config.db.ssl -> src/db/pool.js uses
# ssl:false). Raise to 'true' only against a TLS-terminating DB (e.g. production
# CloudNativePG). 20-deploy-vosj.sh passes this to the chart in pg mode.
export VOSJ_DB_SSL="${VOSJ_DB_SSL:-false}"

# TLS cert verification toward Postgres — ONLY consulted when VOSJ_DB_SSL=true.
# 'false' makes src/db/pool.js connect with ssl:{rejectUnauthorized:false} (no cert
# verification), which is what CloudNativePG self-signed certs need. Irrelevant when
# VOSJ_DB_SSL=false. 20-deploy-vosj.sh passes this to the chart in pg mode.
export VOSJ_DB_SSL_REJECT_UNAUTHORIZED="${VOSJ_DB_SSL_REJECT_UNAUTHORIZED:-false}"

# ----------------------------------------------------------------------------
# Devstations (code-server + Claude dev seat)
# ----------------------------------------------------------------------------
# The product STARTS WITH 5 devstation (Advanced-tier) seats. The ${VAR:-5} form
# means a user's explicit choice always wins over this default — set it via env
# (DEVSTATION_COUNT=8 ./deploy-all.sh) or the deploy-all.sh '--devstation-count N'
# flag. The stage-30 provisioning loop ('for i in $(seq 1 "$DEVSTATION_COUNT")')
# already honors any value, so no manifest change is needed to scale seats.
export DEVSTATION_COUNT="${DEVSTATION_COUNT:-5}"
# Devstation image = the LEAN look-alike (codercom/code-server + Claude Code CLI),
# built from deploy/poc/devstation-image/ by 35-build-devstation-image.sh. It is
# "similar to the devstations we have now" (code-server IDE + `claude` + the same
# Hybrid/AI-only credential model) but light enough to pull onto the small Azure
# Local node — the 1.6GB fleet image claude-code-dev:aks-v2 will not pull there.
# devstation.yaml feeds all config via the per-seat -env Secret (envFrom).
export DEVSTATION_IMAGE="${DEVSTATION_IMAGE:-lucaexpressacr.azurecr.io/vosj-devstation:poc}"
# Per-seat resource sizing. Lean code-server seats are modest; these keep 5 seats
# schedulable on the single 6GB worker. Tune down if seats go Pending.
export DEVSTATION_CPU_REQUEST="${DEVSTATION_CPU_REQUEST:-100m}"
export DEVSTATION_CPU_LIMIT="${DEVSTATION_CPU_LIMIT:-1}"
export DEVSTATION_MEM_REQUEST="${DEVSTATION_MEM_REQUEST:-300Mi}"
export DEVSTATION_MEM_LIMIT="${DEVSTATION_MEM_LIMIT:-1Gi}"
# Port code-server listens on inside the pod.
export DEVSTATION_PORT="${DEVSTATION_PORT:-8080}"
# Claude credential for the dev seats. Leave BLANK here — seats provision "empty"
# (code-server only, autonomous worker off) and a credential is assigned per seat
# afterwards by the Seat Manager website (Hybrid -> CLAUDE_CODE_OAUTH_TOKEN,
# AI-only -> ANTHROPIC_API_KEY). NEVER commit a real token/key to this file.
export CLAUDE_CODE_OAUTH_TOKEN="${CLAUDE_CODE_OAUTH_TOKEN:-}"
# Default Claude model config baked into each fresh seat's -env Secret (mirrors the
# live fleet). The seat stays inert (DEVSTATION_WORKER_ENABLED=false) until the Seat
# Manager assigns a credential + flips the mode.
export DEVSTATION_CLAUDE_MODEL="${DEVSTATION_CLAUDE_MODEL:-opus}"
export DEVSTATION_CLAUDE_FALLBACK_MODEL="${DEVSTATION_CLAUDE_FALLBACK_MODEL:-sonnet}"

# ----------------------------------------------------------------------------
# Local working paths (relative to deploy/poc/). The kubeconfig the provisioner
# fetches is kept OUT of ~/.kube so the POC never clobbers your other contexts.
# ----------------------------------------------------------------------------
# POC_DIR is resolved by each script (dirname of the script). KUBECONFIG path is
# composed from it there; this var documents the convention.
export KUBECONFIG_FILENAME="${KUBECONFIG_FILENAME:-.kube/vosj-poc.config}"

# ----------------------------------------------------------------------------
# Tooling — absolute paths so the scripts are not PATH-dependent. Override if
# your install locations differ. PYTHONIOENCODING avoids an az unicode crash on
# this Windows box.
# ----------------------------------------------------------------------------
export AZ_BIN="${AZ_BIN:-/c/Program Files/Microsoft SDKs/Azure/CLI2/wbin/az}"
export KUBECTL_BIN="${KUBECTL_BIN:-/c/Users/gus/.azure-kubectl/kubectl.exe}"
export HELM_BIN="${HELM_BIN:-helm}"
export PYTHONIOENCODING="${PYTHONIOENCODING:-utf-8}"

# Timeouts (seconds) for long-running waits. 1800s tolerates the FIRST cold pull
# of the ~1.6GB claude-code-dev devstation image onto a small single node (kubelet
# serializes pulls, so the first one blocks the rest — it can take 20-35 min on a
# slow link); once cached on the node, subsequent seats start in seconds.
export ROLLOUT_TIMEOUT="${ROLLOUT_TIMEOUT:-1800}"
export PROVISION_POLL_INTERVAL="${PROVISION_POLL_INTERVAL:-30}"
export PROVISION_POLL_MAX="${PROVISION_POLL_MAX:-120}"   # 120 * 30s = 60 min cap
