{
  "name": "vosj-ce",
  "version": "0.1.0",
  "description": "Vosj Community Edition — open-source, self-hosted, AI-native application-migration & replatforming engine.",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --test",
